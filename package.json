{
  "name": "backend-course-project",
  "version": "1.0.0",
  "description": "Quiz project",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "test": "dotenv -e .env.test -- vitest run --globals --fileParallelism=false",
    "test:watch": "dotenv -e .env.test -- vitest run --globals --fileParallelism=false",
    "test:setup": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test:coverage": "dotenv -e .env.test -- vitest run --coverage --globals --fileParallelism=false"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "express",
    "UEF"
  ],
  "author": "Taisiia",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
